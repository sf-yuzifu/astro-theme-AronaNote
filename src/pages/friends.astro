---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import WalineComment from "../components/WalineComment.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AVATAR, SITE_FAVICON, SITE_URL, FRIENDS, FRIENDS_TITLE, FRIENDS_DESCRIPTION, FRIENDS_ENABLE } from "../consts";

// 从配置文件读取友链配置
const friendsTitle = FRIENDS_TITLE || "友情链接";
const friendsDescription = FRIENDS_DESCRIPTION || "与优秀的开发者们互相连接";

// 判断是否是外部链接
function isExternalUrl(url: string): boolean {
  return url?.startsWith('http://') || url?.startsWith('https://');
}
---

{FRIENDS_ENABLE && (
<BaseLayout
  title={`${friendsTitle} | ${SITE_TITLE}`}
  description={SITE_DESCRIPTION}
  isPost={true}
>
  <!-- Banner内容 -->
  <div slot="banner-content" class="friends-banner">
    <h1 class="title">{friendsTitle}</h1>
    <span class="status">{friendsDescription}</span>
  </div>

  <!-- 友链列表 -->
  <div class="friends-container">
    <h2 class="friends-list-title">
      <Icon name="ph:link-bold" class="info-icon" />
      友链列表
    </h2>
    <ul class="friends-list">
      {
        FRIENDS.map((friend) => (
          <li class="friend-card">
            <a href={friend.url} target="_blank" rel="noopener noreferrer">
              <div class="friend-avatar">
                {friend.avatar ? (
                  isExternalUrl(friend.avatar) ? (
                    <img src={friend.avatar} alt={friend.name} class="avatar-img" loading="lazy" />
                  ) : (
                    <Image src={friend.avatar} alt={friend.name} class="avatar-img" width={56} height={56} />
                  )
                ) : (
                  <Icon name="ph:user-circle-bold" class="avatar-icon" />
                )}
              </div>
              <div class="friend-info">
                <h3>{friend.name}</h3>
                <p>{friend.description}</p>
              </div>
              <Icon name="ph:arrow-right-bold" class="arrow-icon" />
            </a>
          </li>
        ))
      }
    </ul>

    <!-- 本站信息 -->
    <div class="my-info-section">
      <h2>
        <Icon name="ph:info-bold" class="info-icon" />
        本站信息
      </h2>
      <div class="my-info-card">
        <div class="my-info-avatar">
          {isExternalUrl(SITE_AVATAR) ? (
            <img src={SITE_AVATAR} alt={SITE_TITLE} class="avatar-img" loading="lazy" />
          ) : (
            <Image src={SITE_AVATAR} alt={SITE_TITLE} class="avatar-img" width={56} height={56} />
          )}
        </div>
        <div class="my-info-content">
          <div class="my-info-item">
            <span class="label">博客名称</span>
            <span class="value">{SITE_TITLE}</span>
          </div>
          <div class="my-info-item">
            <span class="label">博客地址</span>
            <span class="value">{SITE_URL}</span>
          </div>
          <div class="my-info-item">
            <span class="label">博客图标</span>
            <span class="value">{isExternalUrl(SITE_FAVICON) ? SITE_FAVICON : `${SITE_URL}${SITE_FAVICON}`}</span>
          </div>
          <div class="my-info-item">
            <span class="label">博客介绍</span>
            <span class="value">{SITE_DESCRIPTION}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 申请友链提示 -->
    <div class="apply-section">
      <h2>
        <Icon name="ph:hand-waving-bold" class="wave-icon" />
        交换友链
      </h2>
      <p>欢迎申请友链！请通过下面评论或者首页的联系方式与我联系。</p>
    </div>
  </div>

  <!-- 评论区 -->
  <WalineComment />
</BaseLayout>
)}

<style lang="less">
  .friends-banner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--post-InnerBanner-color);
    text-shadow: 0 0 5px rgba(0, 0, 0, 0.8);
    z-index: 100;
    transition: color 0.5s;

    .title {
      font-size: max(64px, 4.5vw);
      margin-bottom: 50px;
      text-align: center;
      margin-top: 0;
      color: var(--post-InnerBanner-color);
      transition: color 0.5s;
    }

    .status {
      font-size: max(20px, 1vw);
      font-weight: bold;
      color: var(--post-InnerBanner-color);
      transition: color 0.5s;
    }

    @media (max-width: 768px) {
      .title {
        font-size: 5vh;
        margin-bottom: 30px;
      }
      .status {
        font-size: 1.5vh;
      }
    }
  }

  .friends-container {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 1200px;
    width: calc(100% - 48px); // 两侧各留 24px
    position: relative;
    padding: 36px;
    border-radius: 32px;
    border: solid 2px var(--foreground-color);
    background: var(--foreground-color);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.8);
    transition:
      opacity 0.5s ease-out,
      transform 1s cubic-bezier(0.61, 0.15, 0.26, 1),
      border 0.5s,
      background 0.5s,
      box-shadow 0.5s;
    background-image:
      linear-gradient(90deg, rgba(159, 219, 252, 0.15) 3%, transparent 0),
      linear-gradient(1turn, rgba(159, 219, 252, 0.15) 3%, transparent 0);
    background-size: 20px 20px;
    background-position: 50%;

    html[theme="dark"] & {
      background-image:
        linear-gradient(90deg, rgba(207, 198, 254, 0.08) 3%, transparent 0),
        linear-gradient(1turn, rgba(207, 198, 254, 0.08) 3%, transparent 0);
    }
  }

  .friends-list-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 0 20px 0;
    font-size: 20px;
    color: var(--font-color-grey);

    .info-icon {
      width: 24px;
      height: 24px;
      color: var(--font-color-gold);
    }
  }

  .friends-list {
    width: 100%;
    list-style: none;
    padding: 0;
    margin: 0 0 48px 0;
    display: grid;
    gap: 16px;

    .friend-card {
      width: 100%;
      min-width: 0;
      background-color: var(--foreground-color);
      border-radius: 16px;
      border: solid 2px var(--foreground-color);
      transition: all 0.3s ease;
      box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.3);
      overflow: hidden;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0px 0px 15px rgb(var(--blue-shadow-color), 0.5);
        border-color: var(--font-color-gold);
      }

      a {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        text-decoration: none;
        color: inherit;
        min-width: 0;
      }

      .friend-avatar {
        flex-shrink: 0;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background-color: var(--btn-background);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;

        .avatar-icon {
          width: 32px;
          height: 32px;
          color: var(--font-color-gold);
        }

        .avatar-img {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
      }

      .friend-info {
        flex: 1;
        min-width: 0;

        h3 {
          margin: 0 0 6px 0;
          font-size: 18px;
          color: var(--font-color-grey);
          display: -webkit-box;
          word-break: break-word;
          text-overflow: ellipsis;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }

        p {
          margin: 0;
          font-size: 14px;
          color: var(--font-color-grey);
          opacity: 0.7;
          display: -webkit-box;
          word-break: break-word;
          text-overflow: ellipsis;
          -webkit-line-clamp: 3;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
      }

      .arrow-icon {
        flex-shrink: 0;
        width: 20px;
        height: 20px;
        color: var(--font-color-grey);
        opacity: 0.5;
        transition: all 0.3s ease;
      }

      &:hover .arrow-icon {
        opacity: 1;
        color: var(--font-color-gold);
        transform: translateX(4px);
      }
    }
  }

  .my-info-section {
    margin-bottom: 32px;

    h2 {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin: 0 0 20px 0;
      font-size: 20px;
      color: var(--font-color-grey);

      .info-icon {
        width: 24px;
        height: 24px;
        color: var(--font-color-gold);
      }
    }
  }

  .my-info-card {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px;
    background-color: var(--infobox-background-initial);
    border-radius: 16px;
    border: solid 2px var(--font-color-gold);
    box-shadow: 0px 0px 8px rgb(var(--blue-shadow-color), 0.3);

    .my-info-avatar {
      flex-shrink: 0;
      width: 64px;
      height: 64px;
      border-radius: 50%;
      overflow: hidden;
      border: solid 2px var(--font-color-gold);

      .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    .my-info-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .my-info-item {
      display: flex;
      align-items: center;
      gap: 12px;

      .label {
        flex-shrink: 0;
        width: 70px;
        font-size: 14px;
        font-weight: bold;
        color: var(--font-color-grey);
      }

      .value {
        font-size: 14px;
        color: var(--font-color-grey);
        word-break: break-all;
      }
    }
  }

  .apply-section {
    text-align: center;
    padding: 32px;
    background-color: var(--infobox-background-initial);
    border-radius: 16px;
    border: dashed 2px var(--foreground-color);

    h2 {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin: 0 0 12px 0;
      font-size: 20px;
      color: var(--font-color-grey);

      .wave-icon {
        width: 24px;
        height: 24px;
        color: var(--font-color-gold);
      }
    }

    p {
      margin: 0;
      font-size: 14px;
      color: var(--font-color-grey);
      opacity: 0.8;
    }
  }

  @media (max-width: 768px) {
    .friends-container {
      width: calc(100% - 24px); // 两侧各留 12px
      padding: 24px 16px;
      margin: 0 12px;
    }

    .friends-list-title {
      font-size: 18px;
    }

    .friends-list {
      .friend-card {
        a {
          padding: 14px 16px;
          gap: 12px;
        }

        .friend-avatar {
          width: 44px;
          height: 44px;

          .avatar-icon {
            width: 24px;
            height: 24px;
          }

          .avatar-img {
            width: 100%;
            height: 100%;
          }
        }

        .friend-info {
          h3 {
            font-size: 15px;
            margin-bottom: 4px;
          }

          p {
            font-size: 12px;
          }
        }

        .arrow-icon {
          width: 16px;
          height: 16px;
        }
      }
    }

    .my-info-section {
      h2 {
        font-size: 18px;
      }
    }

    .my-info-card {
      flex-direction: column;
      text-align: center;
      gap: 16px;
      padding: 20px;

      .my-info-avatar {
        width: 56px;
        height: 56px;
      }

      .my-info-content {
        gap: 10px;
      }

      .my-info-item {
        flex-direction: column;
        gap: 4px;

        .label {
          width: auto;
        }
      }
    }

    .apply-section {
      padding: 24px 16px;

      h2 {
        font-size: 18px;
      }

      p {
        font-size: 13px;
      }
    }
  }
</style>

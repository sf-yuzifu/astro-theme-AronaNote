---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import PostsList from '../../components/PostsList.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // 提取所有唯一的 tag
  const tags = [...new Set(posts.map((post) => post.data.tags || []).flat())];
  
  return tags.map((tag) => ({
    params: { tag },
    props: {
      // 过滤出包含当前 tag 的文章
      posts: posts.filter((post) => post.data.tags?.includes(tag)).sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
      )
    }
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

// 为了在 Banner 里面渲染所有的 tags，我们需要再次获取全量 tags
const allPosts = await getCollection('blog');
const allTags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Tag: ${tag} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Banner>
      <!-- Tags 卡片显示在 Banner 中 -->
      <ul class="tags-container">
        {allTags.map((t) => (
          <li class:list={['item', { active: t === tag }]}>
            <a href={`/tags/${t}`}><i class="iconfont icon-tag"></i> {t}</a>
          </li>
        ))}
      </ul>
    </Banner>
    <Header />
    <main style="view-transition-name: fade-content;">
      <!-- 直接复用已经写好的 PostsList 组件，只需把过滤后的 posts 传给它 -->
      <PostsList posts={posts} />
    </main>
    <Footer />
  </body>
</html>

<style lang="less">
.tags-container {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  box-sizing: border-box;
  padding: 16px;
  background-color: var(--infobox-background-initial);
  border-radius: 32px;
  border: solid 2px var(--foreground-color);
  backdrop-filter: var(--blur-val);
  width: 768px;
  z-index: 100;
  list-style: none;
  margin: 0;

  li {
    margin: 8px;

    a {
      color: var(--font-color-grey);
      padding: 3px 5px;
      color: var(--font-color-gold);
      background-color: var(--btn-background);
      border-radius: 5px;
      transition: background-color 0.5s;
      text-decoration: none;

      &:hover {
        background-color: var(--btn-hover);
      }
    }
    
    &.active a {
      background-color: var(--btn-hover) !important;
    }
  }
}

@media (max-width: 768px) {
  .tags-container {
    width: auto;
    li {
      margin: 4px;
      a {
        font-size: 12px;
        .icon-tag {
          font-size: 12px;
        }
      }
    }
  }
}
</style>
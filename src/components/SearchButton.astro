---
// 搜索按钮组件
import { Icon } from "astro-icon/components";
---

<span class="search-btn iconfont" id="search-btn" title="搜索">
  <Icon name="ph:magnifying-glass-bold" />
</span>

<script is:inline>
  (function () {
    function initSearchButton() {
      const searchBtn = document.getElementById("search-btn");
      if (searchBtn) {
        // 移除旧的事件监听器
        searchBtn.removeEventListener("click", handleClick);
        // 添加新的事件监听器
        searchBtn.addEventListener("click", handleClick);
      }
    }

    function handleClick() {
      // 触发自定义事件打开搜索对话框
      window.dispatchEvent(new CustomEvent("open-search-dialog"));
    }

    // 初始化
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initSearchButton);
    } else {
      initSearchButton();
    }

    // 页面切换后重新初始化
    document.addEventListener("astro:after-swap", initSearchButton);
  })();
</script>

<style lang="less">
  .search-btn {
    cursor: pointer;
    font-size: max(2vw, 4vh);
    color: var(--font-color-grey);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    display: flex;
    align-items: center;
    justify-content: center;

    &:hover {
      transform: translateY(-3px);
    }

    :global(svg) {
      width: max(2vw, 4vh);
      height: max(2vw, 4vh);
    }
  }

  @media (max-width: 768px) {
    .search-btn {
      font-size: 4vh;

      :global(svg) {
        width: 4vh;
        height: 4vh;
      }
    }
  }
</style>

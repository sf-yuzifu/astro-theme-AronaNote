---
import {
  COMMENTS_ENABLE,
  COMMENTS_TYPE,
  COMMENTS_WALINE_SERVER_URL,
} from "../consts";

interface Props {
  path?: string;
}

const { path } = Astro.props;

// 从配置文件读取评论配置
const enable = COMMENTS_ENABLE && COMMENTS_TYPE === "waline";
const serverURL = COMMENTS_WALINE_SERVER_URL;
---

{
  enable && serverURL && (
    <span class="waline-pageview-wrapper" style="display: none;">
      {" | "}
      <span class="waline-pageview-count" data-path={path}>
        0
      </span>{" "}
      次阅读
    </span>
  )
}

<script>
  // Waline 会自动填充 .waline-pageview-count 元素
  // 我们只需要监听变化并显示组件
  function initPageView() {
    const wrappers = document.querySelectorAll(".waline-pageview-wrapper");

    wrappers.forEach((wrapper) => {
      const countEl = wrapper.querySelector(".waline-pageview-count");
      if (!countEl) return;

      // 检查是否已有数据（Waline 可能已经填充）
      // 只有阅读量大于0时才显示
      const checkAndShow = () => {
        const text = countEl.textContent?.trim();
        const count = parseInt(text || "0", 10);
        // 阅读量大于0才显示
        if (count > 0) {
          (wrapper as HTMLElement).style.display = "inline-flex";
          return true;
        }
        return false;
      };

      // 立即检查
      if (checkAndShow()) return;

      // 监听内容变化
      const observer = new MutationObserver(() => {
        checkAndShow();
      });

      observer.observe(countEl, {
        childList: true,
        characterData: true,
        subtree: true,
      });

      // 5秒后停止监听，但保持隐藏（如果count还是0）
      setTimeout(() => {
        observer.disconnect();
      }, 5000);
    });
  }

  // 页面加载完成后初始化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPageView);
  } else {
    initPageView();
  }

  // Astro 页面切换后重新初始化
  document.addEventListener("astro:page-load", initPageView);
</script>

<style>
  .waline-pageview-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .waline-pageview-count {
    font-weight: 500;
  }
</style>

---
// 音乐控制组件
import { Icon } from "astro-icon/components";
import { getMusicConfig } from "../config";
---

<span
  class="music-control iconfont"
  id="music-control"
  data-music-api={getMusicConfig().api}
  data-music-ids={JSON.stringify(getMusicConfig().songIds)}
  data-music-volume={String(getMusicConfig().volume ?? 0.3)}
  data-music-url-field={getMusicConfig().urlField || "song_data.url"}
>
  <span class="stop-icon" id="music-stop-icon">
    <Icon name="ph:waveform-slash" />
  </span>
  <span class="continue-icon hidden" id="music-continue-icon">
    <Icon name="ph:waveform" />
  </span>
</span>

<script>
  let musicControl: HTMLElement | null = null;
  let stopIcon: HTMLElement | null = null;
  let continueIcon: HTMLElement | null = null;
  let isInitialized = false;

  function updateIcon(playing: boolean) {
    if (stopIcon && continueIcon) {
      if (playing) {
        stopIcon.classList.add("hidden");
        continueIcon.classList.remove("hidden");
      } else {
        continueIcon.classList.add("hidden");
        stopIcon.classList.remove("hidden");
      }
    }
  }

  async function initMusicControl() {
    if (isInitialized) return;
    isInitialized = true;

    musicControl = document.getElementById("music-control");
    stopIcon = document.getElementById("music-stop-icon");
    continueIcon = document.getElementById("music-continue-icon");

    const { initMusic, toggleMusic, configureMusic, getMusicState } =
      await import("../utils/musicService");

    if (musicControl) {
      configureMusic({
        api: musicControl.dataset.musicApi || "",
        songIds: JSON.parse(musicControl.dataset.musicIds || "[]"),
        volume: parseFloat(musicControl.dataset.musicVolume || "0.3"),
        urlField: musicControl.dataset.musicUrlField || "song_data.url",
      });
    }

    initMusic(updateIcon);

    if (getMusicState()) {
      updateIcon(true);
    }

    if (musicControl) {
      musicControl.removeEventListener("click", handleClick);
      musicControl.addEventListener("click", handleClick);
    }

    async function handleClick(e: Event) {
      e.stopPropagation();
      await toggleMusic();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMusicControl);
  } else {
    initMusicControl();
  }

  document.addEventListener("astro:after-swap", initMusicControl);
</script>

<style lang="less">
  .music-control {
    cursor: pointer;
    font-size: max(2vw, 4vh);
    color: var(--font-color-grey);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    display: flex;
    align-items: center;
    justify-content: center;

    &:hover {
      transform: translateY(-3px);
    }

    .stop-icon,
    .continue-icon {
      display: flex;
      align-items: center;
      justify-content: center;

      &.hidden {
        display: none;
      }
    }

    :global(svg) {
      width: max(2vw, 4vh);
      height: max(2vw, 4vh);
    }
  }

  @media (max-width: 768px) {
    .music-control {
      font-size: 4vh;

      :global(svg) {
        width: 4vh;
        height: 4vh;
      }
    }
  }
</style>
